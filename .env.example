# ─────────────────────────────────────────────────────────────
# Pipelyn environment variables
# Copy this file to .env and fill in your values.
# All variables are optional unless marked REQUIRED.
# ─────────────────────────────────────────────────────────────

# ── Server ─────────────────────────────────────────────────
# Port the HTTP server listens on (default: 7990)
PORT=7990

# ── Authentication ─────────────────────────────────────────
# Comma-separated list of valid API keys.
# When set, every request must include  x-api-key: <key>
# Leave blank to disable auth entirely (development / self-hosted).
PIPELYN_API_KEYS=

# ── File size limits ───────────────────────────────────────
# Maximum allowed input file size in bytes.
# Default: 125829120  (120 MiB)
PIPELYN_MAX_INPUT_BYTES=125829120

# ── Storage backend ────────────────────────────────────────
# Set to "s3" to store uploads/outputs in S3-compatible storage.
# Omit (or set to "local") to use local disk storage.
#
# PIPELYN_STORAGE_DRIVER=s3
#
# S3 / R2 / MinIO connection (required when driver=s3):
# PIPELYN_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# PIPELYN_S3_REGION=auto
# PIPELYN_S3_BUCKET=pipelyn
# PIPELYN_S3_ACCESS_KEY_ID=<your-access-key-id>
# PIPELYN_S3_SECRET_ACCESS_KEY=<your-secret-access-key>
# PIPELYN_S3_PUBLIC_URL=https://assets.example.com  # optional CDN prefix

# ── Local storage path ─────────────────────────────────────
# Where job files are stored on disk when using the local driver.
# Default: .pipelyn-store (relative to the project root)
# PIPELYN_STORE_DIR=.pipelyn-store

# ── ffmpeg / ffprobe ───────────────────────────────────────
# Override paths to ffmpeg and ffprobe binaries.
# Defaults to whatever is on PATH.
# PIPELYN_FFMPEG_PATH=/usr/bin/ffmpeg
# PIPELYN_FFPROBE_PATH=/usr/bin/ffprobe
