{
  "name": "web",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "generate": "bunx --bun dex-router generate --pagesDir web/pages --layoutsDir web/layouts --outRoutesTs core/router/.generated/routes.ts --outRoutesJson core/router/.generated/manifest.json --outLayoutsTs core/router/.generated/layouts.ts",
    "prepare:build": "bun scripts/prepare-build.ts",
    "prerender": "bun scripts/prerender.ts",
    "build:css": "bun tailwindcss -i web/styles/index.css -o build/assets/styles.css --minify",
    "build:client": "bun build core/bootstrap/web.tsx --target browser --minify --outfile build/assets/client.js",
    "build:server": "bun build --compile core/runtime/server/prod.ts --outfile build/server",
    "build": "bun run generate && bun run prepare:build && bun run prerender && bun run build:css && bun run build:client && bun run build:server",
    "dev": "bun scripts/dev.ts",
    "start": "NODE_ENV=production ./build/server"
  },
  "dependencies": {
    "@dex/dev": "workspace:*",
    "@dex/pie": "workspace:*",
    "@dex/router": "workspace:*",
    "@dex/server": "workspace:*",
    "@tailwindcss/cli": "^4.1.18",
    "elysia": "^1.4.21",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "bun-types": "latest",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  },
  "dex": {
    "packageVersions": {}
  }
}
